[Unit]
Description=Hermes NapCat QQ Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/YOUR_USER
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/YOUR_USER/.hermes/hermes-agent/venv/bin/python3 /home/YOUR_USER/.hermes/plugins/napcat_qq_bridge/bridge.py run --config-file /home/YOUR_USER/.hermes/napcat_qq_bridge/config.json
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
